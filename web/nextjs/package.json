{
  "name": "nextjs-counsel-embedded-example-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "doppler run -- env NODE_ENV=development next dev -p 3001",
    "build": "NODE_ENV=production next build && mkdir -p .next/standalone/.next && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "PORT=3001 NODE_ENV=production bun run .next/standalone/server.js",
    "lint": "oxlint src/",
    "format": "oxfmt 'src/**/*.{ts,tsx}'",
    "format:check": "oxfmt --check 'src/**/*.{ts,tsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "bun run lint && bun run test"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "iron-session": "^8.0.4",
    "jose": "^6.2.2",
    "lucide-react": "^0.561.0",
    "next": "16.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0",
    "ua-parser-js": "^2.0.7",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "ignoreScripts": ["sharp", "unrs-resolver"],
  "trustedDependencies": ["sharp", "unrs-resolver"],
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tailwindcss": "^4",
    "vitest": "^4.1.2",
    "tw-animate-css": "^1.2.9",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11"
}
