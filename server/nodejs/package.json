{
  "name": "typescript-node-server",
  "version": "1.0.0",
  "description": "A simple TypeScript Node.js HTTP server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "bun src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "compile": "bun build --compile --minify src/index.ts --outfile ./server",
    "compile-and-run": "bun compile && ./server",
    "lint": "oxlint src/",
    "format": "oxfmt 'src/**/*.ts'",
    "format:check": "oxfmt --check 'src/**/*.ts'",
    "dev": "NODE_ENV=development doppler run -- bun --hot src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "bun run lint && bun run test && bun run typecheck && bun run compile",
    "ci": "bun install --production && bun run compile",
    "healthcheck": "sh ./healthcheck.sh"
  },
  "dependencies": {
    "body-parser": "^2.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "standardwebhooks": "^1.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bun-types": "^1.3.11",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "bun@1.3.11"
}
